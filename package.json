{
  "name": "easyk6",
  "version": "1.0.0",
  "description": "K6 Performance Testing Framework with POM (Page Object Model) architecture",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "build:watch": "vite build --watch",
    "validate:build": "node scripts/validate-build.mjs",
    "perf": "node scripts/perf-runner.mjs",
    "smoke": "node scripts/perf-runner.mjs --profile smoke --demo",
    "sync:src": "node scripts/sync-src.mjs",
    "convert-pages": "node scripts/convert-pages.mjs"
  },
  "keywords": [
    "k6",
    "performance-testing",
    "load-testing",
    "pom",
    "page-object-model",
    "testing"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "engineStrict": true,
  "toolVersions": {
    "k6": "1.5.0",
    "node": "22.20.0",
    "npm": "11.6.1"
  },
  "devDependencies": {
    "@types/k6": "0.45.3",
    "glob": "10.4.5",
    "typescript": "5.9.3",
    "vite": "5.4.21",
    "vite-plugin-node-polyfills": "0.19.0"
  },
  "dependencies": {
    "commander": "11.1.0",
    "dotenv": "17.2.3"
  }
}
